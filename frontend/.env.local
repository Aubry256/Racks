# Frontend environment variables
# These are READ by the browser — NEVER put secrets here

# URL of the Django API
# In development: localhost:8000
# In production: https://api.racks.ug
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL for live order tracking
# In development: ws://localhost:8000
# In production: wss://api.racks.ug
NEXT_PUBLIC_WS_URL=ws://localhost:8000
